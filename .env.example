# Gemini AI API Key (Backend - AI işlemleri için)
# Google AI Studio'dan ücretsiz API key alabilirsiniz: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase Credentials
# 1. Supabase Dashboard'dan bir proje oluşturun: https://supabase.com
# 2. Settings → API → Project URL ve anon/public key'i kopyalayın
# 3. Settings → API → service_role key'i kopyalayın (güvenli saklayın!)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Billing Portal URL (opsiyonel, Faz 5'te kullanılacak)
BILLING_URL=https://muhasebeasistani.com/billing

# Iyzico (sadece Supabase Edge Function secrets olarak set edilir; desktop app'e shipping YAPILMAZ)
# supabase secrets set --project-ref <ref> IYZICO_API_KEY=... IYZICO_SECRET_KEY=... IYZICO_MERCHANT_ID=... IYZICO_CALLBACK_URL=https://muhasebeasistani.com/billing/callback
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com  (prod: https://api.iyzipay.com)
# IYZICO_WEBHOOK_VERIFY=false  (ilk entegrasyon testinde imza doğrulamayı devre dışı bırakmak için)
