{
    "name": "muhasebeci-arac-kutusu",
    "private": true,
    "version": "1.0.65",
    "main": "main/main.js",
    "author": {
        "name": "NarWorks",
        "email": "info@narworks.com"
    },
    "description": "Mali Müşavir Otomasyonu",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "electron:dev": "cross-env ELECTRON_RUN_AS_NODE= electron .",
        "dist": "vite build && node scripts/fix-paths.js && node scripts/build-env.js && electron-builder",
        "postinstall": "electron-builder install-app-deps",
        "start": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on tcp:5173 && npm run electron:dev\"",
        "lint": "eslint src/ main/ --ext .ts,.tsx,.js",
        "lint:fix": "eslint src/ main/ --ext .ts,.tsx,.js --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,js,css}\" \"main/**/*.js\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,js,css}\" \"main/**/*.js\"",
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepare": "husky"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@supabase/supabase-js": "^2.93.3",
        "axios": "^1.13.2",
        "better-sqlite3": "^12.5.0",
        "dotenv": "^17.2.3",
        "electron-squirrel-startup": "^1.0.1",
        "electron-updater": "^6.1.8",
        "exceljs": "^4.4.0",
        "iyzipay": "^2.0.64",
        "node-cron": "^4.2.1",
        "pdf-parse": "^2.4.5",
        "puppeteer": "^24.32.0",
        "react": "^18.0.0",
        "react-dom": "^18.0.0",
        "react-router-dom": "^6.22.3",
        "zod": "^3.22.4"
    },
    "lint-staged": {
        "src/**/*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "main/**/*.js": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.4.0",
        "@testing-library/react": "^14.2.0",
        "@types/node": "^24.10.1",
        "@types/react": "^18.0.28",
        "@types/react-dom": "^18.0.11",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "@vitejs/plugin-react": "^3.1.0",
        "@vitejs/plugin-react-swc": "^4.3.0",
        "autoprefixer": "^10.4.19",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^35.7.5",
        "electron-builder": "^26.0.12",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react": "^7.34.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "husky": "^9.1.7",
        "jsdom": "^24.0.0",
        "lint-staged": "^16.4.0",
        "postcss": "^8.4.38",
        "prettier": "^3.2.0",
        "tailwindcss": "^3.4.3",
        "typescript": "^5.9.3",
        "vite": "^4.2.0",
        "vitest": "^1.3.0",
        "wait-on": "^9.0.3"
    }
}
